<script>
function equalizeTestimonials() {
  var maxHeight = 0;
  var wraps = $('.block .single-testimonial .testimonial-wrap');

  // resetiraj visine prije mjerenja
  wraps.css({
    'height': 'auto',
    'display': 'flex',
    'align-items': 'center', // centriranje po vertikali
    'justify-content': 'center', // dodatno centriranje (ako želiš i horizontalno)
    'text-align': 'center', // centriraj tekst
    'flex-direction': 'column' // za sigurnost ako ima više elemenata unutar wrapa
  });

  // izračunaj najveću visinu
  wraps.each(function() {
    var h = $(this).outerHeight();
    if (h > maxHeight) maxHeight = h;
  });

  // primijeni maksimalnu visinu na sve
  wraps.css('height', maxHeight + 'px');
}

// pokreni kad se slick inicijalizira i kad se promijeni slajd
$('.grid-holder.tm_module').on('setPosition', function() {
  equalizeTestimonials();
});

// ponovno izjednači kad se promijeni veličina prozora
$(window).on('resize', equalizeTestimonials);

// pokreni jednom kad se sve učita
$(window).on('load', equalizeTestimonials);

</script>
{% endif %}
{% endfor %}
{% endif %}