{{ header }}{{ column_left }}
<div id="content" class="excetra-import">
  <style>
    .excetra-import .page-header { margin-bottom: 16px; }
    .excetra-import .nav-tabs { margin-bottom: 16px; }
    .excetra-import .panel-heading { padding: 12px 16px; }
    .excetra-import .panel-body { padding: 16px 20px; }
    .excetra-import .form-group { margin-bottom: 10px; }
    .excetra-import .control-label { margin-bottom: 5px; font-size: 12px; color: #666; }
    .excetra-import .excetra-filter .form-control,
    .excetra-import .excetra-actions .form-control { height: 36px; }
    .excetra-import .excetra-actions { background: #fbfbfb; border: 1px solid #e5e5e5; padding: 14px 16px 10px; margin-bottom: 14px; }
    .excetra-import .excetra-options { margin-top: 6px; color: #555; }
    .excetra-import .excetra-options label { margin-right: 22px; font-weight: 400; }
    .excetra-import .table > tbody > tr > td { vertical-align: middle; }
    .excetra-import .excetra-thumb { width: 44px; height: 44px; object-fit: contain; background: #fff; }
    .excetra-import .excetra-product-title { font-weight: 600; max-width: 620px; }
    .excetra-import .excetra-muted { color: #777; font-size: 12px; line-height: 1.6; }
    .excetra-import .excetra-price { white-space: nowrap; }
    .excetra-import .excetra-filter-button { margin-top: 21px; }
  </style>
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="{{ refresh }}" data-toggle="tooltip" title="{{ button_refresh }}" class="btn btn-info"><i class="fa fa-refresh"></i></a>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <ul class="nav nav-tabs">
      <li class="{% if active_tab == 'products' %}active{% endif %}"><a href="{{ products_page }}"><i class="fa fa-list"></i> {{ tab_products }}</a></li>
      <li class="{% if active_tab == 'categories' %}active{% endif %}"><a href="{{ categories_page }}"><i class="fa fa-exchange"></i> {{ tab_mapping }}</a></li>
      <li class="{% if active_tab == 'settings' %}active{% endif %}"><a href="{{ settings_page }}"><i class="fa fa-cog"></i> {{ tab_settings }}</a></li>
    </ul>

    <div class="panel panel-default excetra-filter">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-search"></i> {{ text_filter }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ filter_action }}" method="get">
          <input type="hidden" name="route" value="extension/module/excetra_import" />
          <input type="hidden" name="user_token" value="{{ user_token }}" />
          <div class="row">
            <div class="col-sm-4">
              <label class="control-label" for="input-filter-search">{{ entry_search }}</label>
              <input type="text" name="filter_search" value="{{ filter_search }}" placeholder="{{ entry_search }}" id="input-filter-search" class="form-control" />
            </div>
            <div class="col-sm-4">
              <label class="control-label" for="input-filter-category">{{ entry_supplier_category }}</label>
              <select name="filter_supplier_category_id" id="input-filter-category" class="form-control">
                <option value="">{{ text_all_categories }}</option>
                {% for category in supplier_categories %}
                <option value="{{ category.id }}"{% if category.id == filter_supplier_category_id %} selected="selected"{% endif %}>{{ category.name }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-sm-3">
              <label class="control-label" for="input-filter-import-status">{{ entry_import_status }}</label>
              <select name="filter_import_status" id="input-filter-import-status" class="form-control">
                <option value="">{{ text_all_products }}</option>
                <option value="new"{% if filter_import_status == 'new' %} selected="selected"{% endif %}>{{ text_new_products }}</option>
                <option value="imported"{% if filter_import_status == 'imported' %} selected="selected"{% endif %}>{{ text_imported_products }}</option>
              </select>
            </div>
            <div class="col-sm-1">
              <button type="submit" class="btn btn-primary btn-block excetra-filter-button" data-toggle="tooltip" title="{{ button_filter }}"><i class="fa fa-filter"></i></button>
            </div>
          </div>
        </form>
      </div>
    </div>

    <form action="{{ import }}" method="post" enctype="multipart/form-data" id="form-excetra-products">
      <div class="panel panel-default">
        <div class="panel-heading">
          <h3 class="panel-title"><i class="fa fa-download"></i> {{ text_import_options }}</h3>
        </div>
        <div class="panel-body">
          <div class="excetra-actions">
            <div class="row">
              <div class="col-sm-4">
                <label class="control-label" for="input-category-id">{{ entry_default_category }}</label>
                <select name="category_id" id="input-category-id" class="form-control">
                  <option value="0">{{ text_select_category }}</option>
                  {% for category in local_categories %}
                  <option value="{{ category.category_id }}">{{ category.name }}</option>
                  {% endfor %}
                </select>
              </div>
              <div class="col-sm-2">
                <label class="control-label" for="input-price-mode-import">{{ entry_price_mode }}</label>
                <select name="excetra_import_price_mode" id="input-price-mode-import" class="form-control">
                  {% for key, label in price_modes %}
                  <option value="{{ key }}"{% if key == settings.price_mode %} selected="selected"{% endif %}>{{ label }}</option>
                  {% endfor %}
                </select>
              </div>
              <div class="col-sm-2">
                <label class="control-label" for="input-margin-import">{{ entry_margin }}</label>
                <input type="text" name="excetra_import_margin" value="{{ settings.margin }}" id="input-margin-import" class="form-control" />
              </div>
              <div class="col-sm-2">
                <label class="control-label" for="input-create-parent-import">{{ entry_create_parent_category }}</label>
                <select name="create_parent_category_id" id="input-create-parent-import" class="form-control">
                  <option value="0">{{ text_none }}</option>
                  {% for category in local_categories %}
                  <option value="{{ category.category_id }}">{{ category.name }}</option>
                  {% endfor %}
                </select>
              </div>
              <div class="col-sm-2">
                <button type="submit" class="btn btn-success btn-block excetra-filter-button" onclick="return confirm('{{ text_confirm_import }}');"><i class="fa fa-download"></i> {{ button_import_selected }}</button>
              </div>
            </div>
            <div class="excetra-options">
              <label><input type="checkbox" name="use_category_map" value="1" checked="checked" /> {{ entry_use_category_map }}</label>
              <label><input type="checkbox" name="auto_create_category" value="1" /> {{ entry_auto_create_category }}</label>
              <label><input type="checkbox" name="update_existing_descriptions" value="1" /> {{ entry_update_existing_descriptions }}</label>
              <span class="pull-right">
                <a href="{{ update_products }}" class="btn btn-primary btn-sm" onclick="return confirm('{{ text_confirm_update_products }}');"><i class="fa fa-refresh"></i> {{ button_update_products }}</a>
                <a href="{{ update_prices }}" class="btn btn-info btn-sm" onclick="return confirm('{{ text_confirm_update_prices }}');"><i class="fa fa-money"></i> {{ button_update_prices }}</a>
                <a href="{{ update_quantities }}" class="btn btn-warning btn-sm" onclick="return confirm('{{ text_confirm_update_quantities }}');"><i class="fa fa-cubes"></i> {{ button_update_quantities }}</a>
              </span>
            </div>
          </div>

          <div class="table-responsive">
            <table class="table table-bordered table-hover table-condensed">
              <thead>
                <tr>
                  <td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" /></td>
                  <td style="width: 58px;" class="text-center">{{ column_image }}</td>
                  <td class="text-left">{{ column_product }}</td>
                  <td class="text-left">{{ column_supplier_category }}</td>
                  <td class="text-left">{{ column_local_category }}</td>
                  <td class="text-right">{{ column_quantity }}</td>
                  <td class="text-right">{{ column_price }}</td>
                  <td class="text-center">{{ column_status }}</td>
                </tr>
              </thead>
              <tbody>
                {% if products %}
                {% for product in products %}
                <tr>
                  <td class="text-center"><input type="checkbox" name="selected[]" value="{{ product.code }}" /></td>
                  <td class="text-center">
                    {% if product.image %}
                    <img src="{{ product.image }}" alt="{{ product.name }}" loading="lazy" class="img-thumbnail excetra-thumb" />
                    {% else %}
                    <span class="img-thumbnail excetra-thumb"></span>
                    {% endif %}
                  </td>
                  <td class="text-left">
                    <div class="excetra-product-title">{{ product.name }}</div>
                    <div class="excetra-muted">{{ text_code }}: {{ product.code }}{% if product.barcode %} | EAN: {{ product.barcode }}{% endif %}{% if product.brand %} | {{ product.brand }}{% endif %}</div>
                    {% if product.is_imported and product.edit %}
                    <a href="{{ product.edit }}" target="_blank">{{ text_open_product }}</a>
                    {% endif %}
                  </td>
                  <td class="text-left">{{ product.supplier_category }}</td>
                  <td class="text-left">
                    {% if product.mapped_category %}
                    {{ product.mapped_category }}
                    {% else %}
                    <span class="text-muted">{{ text_not_mapped }}</span>
                    {% endif %}
                  </td>
                  <td class="text-right">
                    {{ product.quantity }}
                    {% if product.local_quantity != '' %}
                    <div class="excetra-muted">{{ text_local }}: {{ product.local_quantity }}</div>
                    {% endif %}
                  </td>
                  <td class="text-right excetra-price">
                    {{ text_price_mpc }}: {{ product.price_mpc }}
                    <div class="excetra-muted">{{ text_price_vpc }}: {{ product.price_vpc }}</div>
                    {% if product.local_price %}
                    <div class="excetra-muted">{{ text_local }}: {{ product.local_price }}</div>
                    {% endif %}
                  </td>
                  <td class="text-center">
                    {% if product.is_imported %}
                    <span class="label label-success">{{ text_imported }}</span>
                    {% else %}
                    <span class="label label-default">{{ text_new }}</span>
                    {% endif %}
                  </td>
                </tr>
                {% endfor %}
                {% else %}
                <tr>
                  <td class="text-center" colspan="8">{{ text_no_results }}</td>
                </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
          <div class="row">
            <div class="col-sm-6 text-left">{{ pagination }}</div>
            <div class="col-sm-6 text-right">{{ results }}</div>
          </div>
        </div>
      </div>
    </form>
  </div>
</div>
{{ footer }}
