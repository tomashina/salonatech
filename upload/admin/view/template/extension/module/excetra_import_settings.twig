{{ header }}{{ column_left }}
<div id="content" class="excetra-import">
  <style>
    .excetra-import .nav-tabs { margin-bottom: 16px; }
    .excetra-import .panel-body { padding: 18px 22px; }
    .excetra-import .form-group { margin-bottom: 16px; }
    .excetra-import .help-block { margin-bottom: 8px; }
  </style>
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_settings }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <ul class="nav nav-tabs">
      <li class="{% if active_tab == 'products' %}active{% endif %}"><a href="{{ products_page }}"><i class="fa fa-list"></i> {{ tab_products }}</a></li>
      <li class="{% if active_tab == 'categories' %}active{% endif %}"><a href="{{ categories_page }}"><i class="fa fa-exchange"></i> {{ tab_mapping }}</a></li>
      <li class="{% if active_tab == 'settings' %}active{% endif %}"><a href="{{ settings_page }}"><i class="fa fa-cog"></i> {{ tab_settings }}</a></li>
    </ul>

    <form action="{{ save }}" method="post" enctype="multipart/form-data" class="form-horizontal">
      <input type="hidden" name="return_route" value="settings" />
      <div class="panel panel-default">
        <div class="panel-heading">
          <h3 class="panel-title"><i class="fa fa-cog"></i> {{ tab_settings }}</h3>
        </div>
        <div class="panel-body">
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-feed-url">{{ entry_feed_url }}</label>
            <div class="col-sm-10">
              <input type="text" value="{{ feed_url }}" id="input-feed-url" class="form-control" readonly="readonly" onclick="this.select();" />
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-price-mode">{{ entry_price_mode }}</label>
            <div class="col-sm-10">
              <select name="excetra_import_price_mode" id="input-price-mode" class="form-control">
                {% for key, label in price_modes %}
                <option value="{{ key }}"{% if key == settings.price_mode %} selected="selected"{% endif %}>{{ label }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-margin">{{ entry_margin }}</label>
            <div class="col-sm-10">
              <input type="text" name="excetra_import_margin" value="{{ settings.margin }}" id="input-margin" class="form-control" />
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-tax-class">{{ entry_tax_class }}</label>
            <div class="col-sm-10">
              <select name="excetra_import_tax_class_id" id="input-tax-class" class="form-control">
                <option value="0">{{ text_none }}</option>
                {% for tax_class in tax_classes %}
                <option value="{{ tax_class.tax_class_id }}"{% if tax_class.tax_class_id == settings.tax_class_id %} selected="selected"{% endif %}>{{ tax_class.title }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-cron-token">{{ entry_cron_token }}</label>
            <div class="col-sm-10">
              <input type="text" name="excetra_import_cron_token" value="{{ settings.cron_token }}" id="input-cron-token" class="form-control" />
              <span class="help-block">{{ help_cron_token }}</span>
              <input type="text" value="{{ cron_url }}" class="form-control" readonly="readonly" onclick="this.select();" />
            </div>
          </div>
          <div class="form-group">
            <div class="col-sm-offset-2 col-sm-10">
              <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
              <a href="{{ update_products }}" class="btn btn-primary" onclick="return confirm('{{ text_confirm_update_products }}');"><i class="fa fa-refresh"></i> {{ button_update_products }}</a>
              <a href="{{ update_prices }}" class="btn btn-info" onclick="return confirm('{{ text_confirm_update_prices }}');"><i class="fa fa-money"></i> {{ button_update_prices }}</a>
              <a href="{{ update_quantities }}" class="btn btn-warning" onclick="return confirm('{{ text_confirm_update_quantities }}');"><i class="fa fa-cubes"></i> {{ button_update_quantities }}</a>
            </div>
          </div>
        </div>
      </div>
    </form>
  </div>
</div>
{{ footer }}
