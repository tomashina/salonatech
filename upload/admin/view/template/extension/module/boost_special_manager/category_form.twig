#}
{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-attribute" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
	  </div>
      <h1>{{ text_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
	{% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_form_category_special }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-product" class="form-horizontal">
  		  
		  <fieldset>
            <legend>{{ text_categories }}</legend>
            <div class="row">	
              <div class="col-sm-6">		
                <div class="form-group" id="fg-category">
                  <label class="col-sm-4 control-label" for="category_id">{{ entry_categories }}</label>
                  <div class="col-sm-8" id="col-category">
                    <select name="category_id[]" id="category_id" class="form-control" multiple="multiple">
                      {% for category in categoriesx %}
				        {% if category.category_id == category_id %}
                          <option value="{{ category.category_id }}" selected="selected">{{ category.name }} ( {{ category.category_id }} )</option>
                        {% else %}
                          <option value="{{ category.category_id }}">{{ category.name }} ( {{ category.category_id }} )</option>
                        {% endif %}
                      {% endfor %}
                    </select>
                  </div>
                </div>
		      </div>
            </div>
		  </fieldset>
		  
		  <fieldset>
            <legend>{{ text_rule }}</legend> 
		  	<div class="row">
              <div class="col-sm-6">
                <div class="form-group">
                  <label class="col-sm-4 control-label" >{{ entry_discount_type }}</label>
                  <div class="col-sm-8">
                    <select name="discount_type" id="input-discount-type" class="form-control">
                      <option value="0" selected="selected">{{ entry_percentage_discount }}</option>
			          <option value="1">{{ entry_fixed_discount }}</option>
                      <option value="2">{{ entry_flat_price }}</option>
                    </select>
                  </div>
                </div>
              </div>
			  <div class="col-sm-6">
                <div class="form-group">
                  <label class="col-sm-4 control-label" for="input-customer-group">{{ entry_customer_groups }}</label>
                  <div class="col-sm-8">
                    <select name="customer_group_id" id="input-customer-group" class="form-control">
                      <option value="0">{{ text_select }}</option>
                      {% for customer_group in customer_groups %}
                        {% if customer_group.customer_group_id == customer_group_id %}
                          <option value="{{ customer_group.customer_group_id }}" selected="selected">{{ customer_group.name }}</option>
                        {% else %}
                          <option value="{{ customer_group.customer_group_id }}">{{ customer_group.name }}</option>
                        {% endif %}
                      {% endfor %}
                    </select>
                    {% if error_customer_group_id %}
                      <div class="text-danger">{{ error_customer_group_id }}</div>
                    {% endif %}
				  </div>
                </div>
              </div>
		    </div>
		    <div class="row">	
              <div class="col-sm-6">
                <div class="form-group">
                  <label class="col-sm-4 control-label" for="price">{{ entry_value }}</label>
                  <div class="col-sm-8">
                    <input type="text" name="price" value="" placeholder="{{ entry_value }}" id="price" class="form-control" />
                    {% if error_value %}
                    <div class="text-danger">{{ error_value }}</div>
                    {% endif %}
                  </div>
                </div>
              </div>
              <div class="col-sm-6">
                <div class="form-group">
                  <label class="col-sm-4 control-label" for="priority">{{ entry_priority }}</label>
                  <div class="col-sm-8">
                    <input type="text" name="priority" value="" placeholder="{{ entry_priority }}" id="priority" class="form-control" />
                  </div>
                </div>
              </div>
		    </div>
			<div class="row">
              <div class="col-sm-6">
                <div class="form-group">
                  <label class="col-sm-4 control-label" for="input-date-start">{{ entry_date_start }}</label>
                  <div class="col-sm-8">
                    <div class="input-group date"><input type="text" name="date_start" id="input-date-start" value="" placeholder="{{ entry_date_start }}" data-date-format="YYYY-MM-DD" class="form-control"><span class="input-group-btn"><button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button></span></div>
                  </div>
                </div>
              </div>
              <div class="col-sm-6">
                <div class="form-group">
                  <label class="col-sm-4 control-label" for="input-date-end">{{ entry_date_end }}</label>
                  <div class="col-sm-8">
			        <div class="input-group date"><input type="text" name="date_end" id="input-date-end" value="" placeholder="{{ entry_date_end }}" data-date-format="YYYY-MM-DD" class="form-control"><span class="input-group-btn"><button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button></span></div>
                  </div>
                </div>
              </div>
            </div>
		  </fieldset>
	    </form>
      </div>
    </div>
  </div>
  
  {{ footer }}

</div>

{% if error_category_id %}
  <style>
  .select2-container--default .select2-selection--multiple {
    border: 1px solid red !important;
   }
  </style>
{% endif %}

<script type="text/javascript">
  $("#form-product").on('submit', function(){
      $("#form-product").append("<input type='hidden' name='ProductList' value='"+$("#category_id").select2("val")+"' />");
  });

  $('.date').datetimepicker({
	  language: 'en-gb',
	  pickTime: false
  });

  $('.time').datetimepicker({
	  language: 'en-gb',
	  pickDate: false
  });

  $('.datetime').datetimepicker({
	  language: 'en-gb',
	  pickDate: true,
	  pickTime: true
  });
  
  $(document).ready(function() {
      $('#category_id').select2();
	
      {% if error_category_id %}
		  console.log('{{ error_category_id }}');
		  $('#col-category').append('<div class="text-danger">{{ error_category_id }}</div>');
		  $('#fg-category').attr('class','form-group has-error');
	  {% endif %}
	
  });  
</script>
